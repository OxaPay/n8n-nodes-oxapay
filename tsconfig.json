{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    "declaration": true,
    "sourceMap": true,

    "outDir": "dist",
    "rootDir": ".",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true

  },
  "include": [
    "nodes/**/*.ts",
    "credentials/**/*.ts",
    "helpers.ts",
    "index.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}